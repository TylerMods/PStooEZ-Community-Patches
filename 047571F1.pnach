[Player Special Type Modifier]
author=bungholio
description=It doesn&#039;t matter what the special is for the player you choose, this will set
it to what you choose.  These are the digits:
0 = True Speed
1 = Swift Attack
2 = Volley
3 = Fire
4 = Rockfall
patch=1,EE,2137A6EC,extended,82A1D170
patch=1,EE,5056D426,extended,9B453313
patch=1,EE,00000000,extended,00000000

