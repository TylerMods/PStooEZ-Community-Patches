[Menu BGM Modifier]
author=AceKombat
description=Contains three unused/leftover tracks. Values are as followed:

00 = "Soulus" [Leftover: Eternal Ring]
01 = Menu BGM [Beta: Playtest Build]
02 = "Shape Memory Alloys (Remix)" [Beta: Unknown Origin]
03 = Menu BGM "Roundabout" [Final]
patch=1,EE,201E52E4,extended,24040000

