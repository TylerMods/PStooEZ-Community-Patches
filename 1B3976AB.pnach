[Jak Size Modifier]
author=bungholio
description=It will only make him look bigger, you won&#039;t be able to hit farther or anything like that.

3f000000 or 00000000 default
floats between 0 and 1 make him bigger
floats higher than 1 make him smaller
negative floats flip him upside down
patch=1,EE,401803A0,extended,00040001
patch=1,EE,3F000000,extended,00000000

