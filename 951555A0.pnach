patch=1,EE,00D5873D,extended,0000005D
patch=1,EE,51E95ACF,extended,5710D5B0
patch=1,EE,00000000,extended,00000000

[Main Area Modifier]
author=bungholio
description=04 = Holt Village
08 = Coliseum
10 = Land Of Carnage
78 = Coliseum Depths
Not very useful. The digits are about identical, they just keep repeating in some order of nothing, Holt Village, Coliseum, Land Of Carnage, and Coliseum Depths.
patch=1,EE,00333276,extended,00000004

