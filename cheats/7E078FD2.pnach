[P1 Character Modifier]
author=Hacc
description=Only use one of these codes in Arcade mode. 

00 - Gill
01 - Alex
02 - Ryu
03 - Yun
04 - Dudley
05 - Necro
06 - Hugo
07 - Ibuki
08 - Elena
09 - Oro
0A - Yang
0B - Ken
0C - Sean
0D - Urien
0E - Gouki
0F - Chun-Li
10 - Makoto
11 - Q
12 - Twelve
13 - Remy
patch=1,EE,51D41E23,extended,FD34C211
patch=1,EE,00000000,extended,00000000

[P1 Costume Modifier]
author=Hacc
description=00 - Color 1 (Square)
01 - Color 2 (Triangle)
02 - Color 3 (R1)
03 - Color 4 (X)
04 - Color 5 (Circle)
05 - Color 6 (L1)
06 - Color 7 (Secret)
07 - Color 8 (Start+Square)
08 - Color 9 (Start+Triangle)
09 - Color 10 (Start+R1)
0A - Color 11 (Start+X)
0B - Color 12 (Start+Circle)
0C - Color 13 (Start+L1)
0D - Shadow
patch=1,EE,507D5CBD,extended,C2F9063E
